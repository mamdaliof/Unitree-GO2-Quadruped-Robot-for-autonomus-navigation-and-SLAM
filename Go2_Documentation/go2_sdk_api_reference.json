{
  "network": {
    "dock_pc_ip": "192.168.123.18",
    "lidar_ip": "192.168.123.20",
    "motion_control_pc_ip": "192.168.123.161",
    "user_pc_target_ip": "192.168.123.99",
    "ssh_user": "unitree",
    "ssh_password": "123"
  },
  "topics": {
    "dds_only": [
      {
        "topic": "rt/sportmodestate",
        "type": "unitree_go::msg::dds_::SportModeState_",
        "direction": "publish",
        "description": "High-level state containing robot position, velocity, and orientations."
      },
      {
        "topic": "rt/lowstate",
        "type": "unitree_go::msg::dds_::LowState_",
        "direction": "publish",
        "description": "Low-level motor feedback, joint angles, battery status, and BMS data."
      },
      {
        "topic": "rt/utlidar/cloud",
        "type": "sensor_msgs::msg::dds_::PointCloud2_",
        "direction": "publish",
        "description": "Raw 3D point cloud in lidar coordinate frame (utlidar_lidar)."
      },
      {
        "topic": "rt/utlidar/cloud_deskewed",
        "type": "sensor_msgs::msg::dds_::PointCloud2_",
        "direction": "publish",
        "description": "Point cloud corrected for body motion, represented in world odom frame."
      },
      {
        "topic": "rt/utlidar/height_map_array",
        "type": "unitree_go::msg::dds_::HeightMap_",
        "direction": "publish",
        "description": "2D elevation map centered on the robot for obstacle and stair traversal."
      },
      {
        "topic": "rt/utlidar/range_info",
        "type": "geometry_msgs::msg::dds_::PointStamped_",
        "direction": "publish",
        "description": "Simplified obstacle distances: x = front, y = left, z = right."
      },
      {
        "topic": "rt/utlidar/switch",
        "type": "std_msgs::msg::dds_::String_",
        "direction": "subscribe",
        "description": "Control topic to turn lidar ON or OFF (send 'ON' or 'OFF')."
      },
      {
        "topic": "rt/slam_info",
        "type": "std_msgs::msg::dds_::String_",
        "direction": "publish",
        "description": "JSON string containing relocation state, hardware stats, or active control paths."
      },
      {
        "topic": "rt/slam_key_info",
        "type": "std_msgs::msg::dds_::String_",
        "direction": "publish",
        "description": "JSON feedback indicating task execution success and node arrivals."
      }
    ],
    "ros2_mapping": {
      "prefix_rule": "The 'rt/' prefix in DDS topics is stripped in ROS 2.",
      "examples": {
        "rt/utlidar/cloud_deskewed": "/utlidar/cloud_deskewed",
        "rt/sportmodestate": "/sportmodestate",
        "rt/lowstate": "/lowstate"
      }
    }
  },
  "slam_api": {
    "service_name": "slam_operate",
    "version": "1.0.0.1",
    "api_ids": {
      "1801": {
        "action": "start_mapping",
        "input_schema": {
          "data": { "slam_type": "indoor" }
        }
      },
      "1802": {
        "action": "end_mapping",
        "input_schema": {
          "data": { "address": "/path/to/save.pcd" }
        }
      },
      "1804": {
        "action": "initialize_pose",
        "input_schema": {
          "data": {
            "x": 0.0, "y": 0.0, "z": 0.0,
            "q_x": 0.0, "q_y": 0.0, "q_z": 0.0, "q_w": 1.0,
            "address": "/path/to/load.pcd"
          }
        }
      },
      "1102": {
        "action": "pose_navigation",
        "input_schema": {
          "data": {
            "targetPose": {
              "x": 2.0, "y": 0.0, "z": 0.0,
              "q_x": 0.0, "q_y": 0.0, "q_z": 0.0, "q_w": 1.0
            },
            "mode": 1,
            "speed": 0.5
          }
        },
        "notes": "Modes: 1 = Stop at obstacles, 0 = Bypass obstacles. Target range limit: 10m."
      },
      "1201": {
        "action": "pause_navigation"
      },
      "1202": {
        "action": "resume_navigation"
      },
      "1901": {
        "action": "close_slam"
      }
    }
  },
  "enumerations": {
    "sport_mode": {
      "0": "idle / default stand",
      "1": "balanceStand",
      "2": "pose",
      "3": "locomotion",
      "5": "lieDown",
      "6": "jointLock",
      "7": "damping",
      "8": "recoveryStand",
      "10": "sit",
      "11": "frontFlip",
      "12": "frontJump",
      "13": "frontPounce"
    },
    "gait_type": {
      "0": "idle",
      "1": "trot",
      "2": "run",
      "3": "climb stair",
      "4": "forwardDownStair",
      "9": "adjust"
    }
  }
}
