{
  "_CONFIG_NOTES": {
    "lidar_tilt": "Me do not use repository tilt of 15.1 degrees. Keep catalog value of 13.0 degrees for now. User will calculate real tilt.",
    "calibration": "Me need distinct calibration phase for all sensors.",
    "setup_phase": "Me run accuracy diagnostics once at start. Static IMU drift check, walk 1 meter forward check, spin check.",
    "self_filter": "Me filter out point cloud hits on chassis and legs.",
    "debug_mode": "Me support debug mode to measure processing times of code blocks."
  },
  "nodes": {
    "sensor_publisher_node_name": "go2_sensor_publisher"
  },
  "topics": {
    "l1_lidar_input": "/utlidar/cloud",
    "l1_lidar_output": "/go2/l1_lidar",
    "l2_lidar_input": "/utlidar/cloud_l2",
    "l2_lidar_output": "/go2/l2_lidar",
    "l1_imu_input": "/utlidar/imu",
    "l1_imu_output": "/go2/l1_imu",
    "l2_imu_input": "/utlidar/imu_l2",
    "l2_imu_output": "/go2/l2_imu"
  },
  "system": {
    "target_localization_accuracy_m": 0.05,
    "allowable_slope_angle_deg": "PENDING_RESEARCH",
    "dynamic_speed_scaling": true,
    "sampling_frequency_hz": 500.0,
    "debug_mode": {
      "enabled": false,
      "log_block_process_times": true
    }
  },
  "sensors": {
    "active_lidars": "L1",
    "l1_lidar_tilt_angle_deg": 13.0,
    "l2_lidar_tilt_angle_deg": 15.0,
    "imu_calibration_required": true,
    "self_filter_box": {
      "x_min": -0.7,
      "x_max": -0.1,
      "y_min": -0.3,
      "y_max": 0.3,
      "z_min": -0.6,
      "z_max": 0.0
    },
    "calibration_phase": {
      "enabled": true,
      "imu_static_calib": true,
      "lidar_tilt_calib": true
    },
    "setup_accuracy_check": {
      "enabled": true,
      "check_imu_static_drift": true,
      "check_translation_1m": true,
      "check_rotation": true
    }
  },
  "locomotion": {
    "max_linear_velocity_m_s": 1.0,
    "min_battery_reserve_pct": 15.0,
    "movement_modes": {
      "relative_positioning": true,
      "absolute_positioning": true
    }
  },
  "safety": {
    "sensor_loss_action": "STAND_STILL",
    "network_lag_action": "STAND_STILL",
    "human_proximity_slowdown": {
      "enabled_in_phase_1": false,
      "slowdown_radius_m": 2.0,
      "target_slowdown_velocity_m_s": 0.3
    }
  }
}
